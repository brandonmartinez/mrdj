# Application Environment
NODE_ENV=production
PORT=3000

# Public URLs
CLIENT_URL=https://mrdj.${NETWORK_HOSTNAME_SUFFIX}
API_URL=https://mrdj.${NETWORK_HOSTNAME_SUFFIX}/api

# Database Connection (shared cluster PostgreSQL via PgBouncer)
# PgBouncer endpoint: postgres-svc.data.svc.cluster.local:5432
# Database: mrdj (to be created via postgres-init ConfigMap in data namespace)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-svc.data.svc.cluster.local:5432/mrdj

# Google SSO (see .env.secret for credentials)
GOOGLE_CALLBACK_URL=https://mrdj.${NETWORK_HOSTNAME_SUFFIX}/api/auth/google/callback

# Payment Provider (TBD - Open Decision O1)
# TODO: Add payment provider config once O1 is decided
# STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}  # or PayPal/Amazon Pay equivalents
# PAYMENT_WEBHOOK_SECRET=${PAYMENT_WEBHOOK_SECRET}

# Music Providers (Open Decision O6 - both vs one first)
# TODO: Confirm with Livingston which provider(s) to enable for MVP
# APPLE_MUSIC_TEAM_ID=${APPLE_MUSIC_TEAM_ID}
# APPLE_MUSIC_KEY_ID=${APPLE_MUSIC_KEY_ID}
# SPOTIFY_CLIENT_ID=${SPOTIFY_CLIENT_ID}

# Realtime Transport (Open Decision O3 - WebSocket vs SSE)
# TODO: Add WebSocket/SSE config once O3 is decided

# Guest rate limiting (Epic 9 / #57)
# Per-IP + per-session fixed-window guards on the unauthenticated guest endpoints
# (POST /api/events/:slug/requests, GET /api/tracks/search). Enforced PER REPLICA — with the
# HPA at 2–3 pods the effective ceiling is the value below × replica count, which is acceptable
# for a coarse abuse guard. On by default when NODE_ENV=production. The pod sits behind Traefik
# and the app sets `trust proxy`, so req.ip resolves the real client via X-Forwarded-For.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_REQUEST_PER_IP=60
RATE_LIMIT_REQUEST_PER_SESSION=20
RATE_LIMIT_SEARCH_PER_IP=120
RATE_LIMIT_SEARCH_PER_SESSION=40
