# mrdj — non-secret runtime config (Kustomize configMapGenerator source → mrdj-configmap)
#
# Copy to k8s/.env (gitignored) for a real deploy. ONLY non-secret values belong here; anything
# carrying credentials (DATABASE_URL, SESSION_SECRET, Stripe/Google secrets) goes in the secret
# template below. These keys mirror exactly what the app reads in api/src/config/index.ts — no
# stale/aspirational names. Kustomize does NOT interpolate ${...}, so every value is concrete.

# ── Runtime ─────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Realtime broker. Keep in-process until the deploy wave wires a direct Postgres DSN
# and intentionally enables multi-replica LISTEN/NOTIFY with REALTIME_TRANSPORT=pg.
REALTIME_TRANSPORT=in-process

# Public origin (Traefik terminates TLS). Used for OAuth redirect + SPA base.
WEB_BASE_URL=https://mrdj.themartinez.cloud
GOOGLE_REDIRECT_URI=https://mrdj.themartinez.cloud/api/auth/google/callback

# ── Music providers (Epic 5 — O6 resolved: iTunes for MVP, no credentials) ─────────────
MUSIC_PROVIDER=itunes
ITUNES_STOREFRONT=US
ITUNES_MAX_ATTEMPTS=3
ITUNES_REQUEST_TIMEOUT_MS=4000
ITUNES_TOTAL_TIMEOUT_MS=9000
ITUNES_BASE_DELAY_MS=300
ITUNES_MAX_DELAY_MS=2000
ITUNES_RETRY_AFTER_MAX_MS=2000
ITUNES_MAX_TOTAL_BACKOFF_MS=3000

# ── Payments / Stripe Connect (Epic 4 — O1 resolved: Stripe). Non-secret knobs only. ──
PLATFORM_FEE_PERCENT=10
PAYMENTS_CURRENCY=usd
STRIPE_CONNECT_REFRESH_URL=https://mrdj.themartinez.cloud/connect/refresh
STRIPE_CONNECT_RETURN_URL=https://mrdj.themartinez.cloud/connect/return
REFUND_WINDOW_MS=2592000000

# ── Guest rate limiting (Epic 9 / #57) ────────────────────────────────────────────────
# Per-IP + per-session fixed-window guards, enforced PER REPLICA (effective ceiling scales with
# the HPA replica count — acceptable coarse abuse guard). On by default when NODE_ENV=production.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_REQUEST_PER_IP=60
RATE_LIMIT_REQUEST_PER_SESSION=20
RATE_LIMIT_SEARCH_PER_IP=120
RATE_LIMIT_SEARCH_PER_SESSION=40
