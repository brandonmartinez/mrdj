# SECURITY: This file contains SECRET placeholders
# NEVER commit the real .env.secret file to git
# Real secrets go in .env.secret.temp (gitignored)

# Database credentials (from shared cluster data namespace)
POSTGRES_USER=rpi
POSTGRES_PASSWORD=<cluster-postgres-password>

# Google SSO secrets
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# JWT secret for session tokens
JWT_SECRET=<generate-secure-random-string>

# Payment Provider secrets (TBD - Open Decision O1)
# STRIPE_SECRET_KEY=<stripe-secret-key>  # or PayPal/Amazon Pay equivalents
# PAYMENT_WEBHOOK_SECRET=<webhook-secret>

# Music Provider secrets (Open Decision O6)
# APPLE_MUSIC_PRIVATE_KEY=<base64-encoded-p8-key>
# SPOTIFY_CLIENT_SECRET=<spotify-client-secret>
