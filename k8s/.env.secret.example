# mrdj — SECRET config (Kustomize secretGenerator source → mrdj-secret)
#
# SECURITY: this *.example file holds PLACEHOLDERS only and is committed for documentation.
# Real values go in k8s/.env.secret.temp (gitignored, referenced by kustomization.yml). NEVER
# commit real secrets. Keys mirror exactly what api/src/config/index.ts reads. Kustomize does
# NOT interpolate, so DATABASE_URL must be a COMPLETE connection string (not built from parts).

# ── Database (shared cluster PostgreSQL via PgBouncer in the data namespace) ───────────
# Full DSN — embeds the cluster Postgres user + password. mrdj database created by
# init-mrdj-db.sh (story #45). Use the PgBouncer service DNS.
DATABASE_URL=postgresql://rpi:<cluster-postgres-password>@postgres-svc.data.svc.cluster.local:5432/mrdj

# Dedicated direct Postgres DSN for REALTIME_TRANSPORT=pg. Do NOT route through
# PgBouncer transaction pooling; LISTEN needs a stable session connection.
REALTIME_DATABASE_URL=postgresql://rpi:<cluster-postgres-password>@postgres-primary.data.svc.cluster.local:5432/mrdj

# ── Session signing (express-session cookie secret) ───────────────────────────────────
SESSION_SECRET=<generate-64-char-random-string>

# ── Google OAuth2 SSO (Epic 3) ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ── Stripe Connect (Epic 4 — O1 resolved). Test-mode keys for staging, live for prod. ──
STRIPE_SECRET_KEY=<sk_live_or_test_...>
STRIPE_PUBLISHABLE_KEY=<pk_live_or_test_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>

# ── Music provider secrets ────────────────────────────────────────────────────────────
# iTunes (the MVP provider) needs NO credentials. Apple Music / Spotify are post-MVP
# scaffolds — add their secrets here only when those providers are enabled.
# APPLE_MUSIC_PRIVATE_KEY=<contents-of-.p8-key-newlines-preserved>
# SPOTIFY_CLIENT_SECRET=<spotify-client-secret>
