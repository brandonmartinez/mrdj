# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mrdj:mrdj@localhost:5432/mrdj

# Postgres service credentials (docker-compose db service)
POSTGRES_USER=mrdj
POSTGRES_PASSWORD=mrdj
POSTGRES_DB=mrdj

# ── API ──────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# IMPORTANT: change to a 64-char random string in production
SESSION_SECRET=dev-secret-change-in-prod

# Where the browser is sent after a successful login (SPA origin)
WEB_BASE_URL=http://localhost:5173

# ── Auth: Google OAuth2 SSO (Epic 3) ──────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials :
#   1. Create an OAuth consent screen (External), scopes: openid, email, profile.
#   2. Create an "OAuth client ID" of type "Web application".
#   3. Add the redirect URI below to "Authorized redirect URIs".
# Leave these blank in local dev to use the built-in stub provider (dev only —
# the stub is refused when NODE_ENV != development). NEVER commit real secrets.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback


# ── Music providers (Epic 5) ──────────────────────────────────────────────────────
# Active catalog provider for /api/tracks/search. Default 'itunes' needs NO credentials
# (Apple's public iTunes Search API). 'spotify'/'apple' are scaffolds (require the env
# below + code completion); 'stub' serves only seeded local tracks.
MUSIC_PROVIDER=itunes
# Re-resolve cached tracks older than this (ms) to refresh expiring preview URLs. Default 24h.
TRACK_CACHE_TTL_MS=86400000
# iTunes Search API (no key required).
ITUNES_BASE_URL=https://itunes.apple.com
ITUNES_STOREFRONT=US

# Spotify (SCAFFOLD — not wired). Spotify's Web API now requires a Premium account, so
# the MVP ships on iTunes. Provide these only when enabling the Spotify provider.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Apple Music MusicKit (SCAFFOLD — fast-follow). The .p8 private key contents go in
# APPLE_MUSIC_PRIVATE_KEY (newlines preserved). NEVER commit real secrets.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# ── Payments / Stripe Connect (Epic 4) ───────────────────────────────────────
# Marketplace payments via Stripe Connect Express. Secrets via env ONLY — never
# commit real keys. CI/tests use recorded fixtures (nock), so no keys are needed
# to run the suite; provide test-mode keys (sk_test_…/pk_test_…) for the manual
# end-to-end smoke (story #63).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…) from `stripe listen` or the dashboard endpoint.
STRIPE_WEBHOOK_SECRET=
# Platform application fee on each guest credit purchase (percent). Default 10.
PLATFORM_FEE_PERCENT=10
# Settlement currency for PaymentIntents.
PAYMENTS_CURRENCY=usd
# Connect Express Account Link redirect targets (where Stripe returns the DJ).
STRIPE_CONNECT_REFRESH_URL=http://localhost:5173/connect/refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:5173/connect/return
# Card-refund policy window (ms). Outside this window refunds are credits-only (O7). Default 30d.
REFUND_WINDOW_MS=2592000000
